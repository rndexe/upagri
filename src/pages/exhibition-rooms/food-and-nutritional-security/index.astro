---
import Page from "@layouts/Page.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro"
import Title from "@components/Title.astro"
import Card from "@components/Card.astro";

const trail = [
    { title: "Home", url: "/" },
    { title: "Exhibition Rooms", url: "/exhibition-rooms" },
    { title: "Food and nutritional security", url: "/exhibition-rooms/food-and-nutritional-security" }
]
---

<Page>
    <Breadcrumbs {trail} slot="breadcrumb" />
    <Title slot="title" title="Food and nutritional security"/>
    <div class="flex h-80 gap-8">
        <div class="min-h-full w-full lg:w-1/2">
        <Card text="Enter" link="/exhibition-rooms/food-and-nutritional-security/food-and-nutritional-security-in-tanzania"
            image="/assets/11.2/Photo 1A.jpg">
            <h3 class="text-white">Food and Nutritional Security in Tanzania</h3>
        </Card>
        </div>
    </div>
</Page>