---
import Page from "@layouts/Page.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro"
import Title from "@components/Title.astro"

const trail = [
    { title: "Home", url: "/" },
    { title: "Exhibition Rooms", url: "/exhibition-rooms" },
    { title: "Environmental sustainability", url: "/exhibition-rooms/environmental-sustainability" }
]
---

<Page>
    <Breadcrumbs {trail} slot="breadcrumb" />
    <Title slot="title" title="Environmental sustainability"/>
</Page>