---
import Page from "@layouts/Page.astro"
import Breadcrumbs from "@components/Breadcrumbs.astro"
import Slider from "@components/Slider.astro";
import Title from "@components/Title.astro";

const images = [
    "/assets/showcasing-upa/1.jpg",
    "/assets/showcasing-upa/2.jpg",
    "/assets/showcasing-upa/Placeholder image (India 1)_2.jpg",
    "/assets/showcasing-upa/Placeholder image (India 2).jpg",
]

const links = [
    {
        "title": "Garden City's farming habits",
        "href": "/what-is-upa/showcasing-upa/garden-citys-farming-habits"
    },
    {
        "title": "Gardening per square foot",
        "href": "/what-is-upa/showcasing-upa/gardening-per-square-foot"
    },
    {
        "title": "Changing Rivers, Changing Practices",
        "href": "/what-is-upa/showcasing-upa/changing-rivers-changing-practices"
    },
    {
        "title": "Lorem Ipsum",
        "href": "#"
    }

]

//TODO load this data from a file?
const trail = [
    { title: "Home", url: "/" },
    { title: "What is UPA", url: "/what-is-upa" },
    { title: "Showcasing UPA", url: "/what-is-upa/showcasing-upa" }
]

---

<Page>
    <Breadcrumbs {trail} slot="breadcrumb" />
    <Title slot="title" title="Showcasing UPA" subtitle="Insights from the field" />
    <Slider {images} {links} client:load />
</Page>